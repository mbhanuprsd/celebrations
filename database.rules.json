{
  "rules": {
    "onlineUsers": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['uid', 'name'])"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$roomId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "canvas": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "chat": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".validate": "newData.hasChildren(['userId', 'text', 'type'])"
        }
      }
    }
  }
}
